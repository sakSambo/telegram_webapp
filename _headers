/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' https://telegram.org https://cdn.jsdelivr.net 'wasm-unsafe-eval'; script-src-elem 'self' https://telegram.org https://cdn.jsdelivr.net; connect-src 'self' https:; img-src 'self' data: blob:; media-src 'self' blob:; style-src 'self' 'unsafe-inline'; worker-src 'self' blob: https://cdn.jsdelivr.net; child-src 'self' blob:; form-action 'none'; upgrade-insecure-requests
  Permissions-Policy: camera=(self), microphone=()
  Referrer-Policy: no-referrer
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  X-Permitted-Cross-Domain-Policies: none

/app.js
  Cache-Control: no-cache

/config.js
  Cache-Control: no-cache

/models/*
  Cache-Control: public, max-age=31536000, immutable

/labels/*
  Cache-Control: no-cache
